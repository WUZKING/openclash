payload:

# ===== Gemini Web =====
DOMAIN-SUFFIX,gemini.google.com
DOMAIN-SUFFIX,bard.google.com

# ===== Gemini API & 核心长连接 =====
DOMAIN,generativelanguage.googleapis.com
DOMAIN,assistant-pa.googleapis.com
DOMAIN,proactivebackend-pa.googleapis.com
DOMAIN,embeddedassistant.googleapis.com

# ===== 修复 iOS App 历史会话与登录的关键底层验证 =====
DOMAIN,play.googleapis.com
DOMAIN,googleconfig.googleapis.com
DOMAIN,speech.googleapis.com
DOMAIN,clients3.google.com
DOMAIN,clients4.google.com
DOMAIN-SUFFIX,geller-pa.googleapis.com

# ===== 彻底拦截 Google 移动端硬核风控与环境审查 =====

# 1. 谷歌移动端安全与风控核心（iOS 客户端最常调用的隐藏接口）
DOMAIN-SUFFIX,googleusercontent.com
DOMAIN-SUFFIX,google-analytics.com

# 2. 谷歌全局认证与服务配置（全域后缀，防止 App 绕过精准域名）
DOMAIN-SUFFIX,googleapis.com.cn
DOMAIN-SUFFIX,googlesyndication.com

# 3. 补充可能漏掉的 API 细分域名
DOMAIN,mobile-gtm.googleapis.com
DOMAIN,securetoken.googleapis.com

# 谷歌全局核心静态资源与策略（App 初始化最关键的底层，BlackMatrix7 里的核心）
DOMAIN-SUFFIX,gstatic.com
DOMAIN-SUFFIX,google.dev

# 谷歌底层全局 API 细分（App 本地化认证与安全凭证组件）
DOMAIN-SUFFIX,google-apis.com
DOMAIN,identitytoolkit.googleapis.com
DOMAIN,securetoken.google.com

# ===== 历史会话 / 同步 =====
DOMAIN,content-push.googleapis.com
DOMAIN,people-pa.googleapis.com

# ===== 登录与账号基础设施 =====
DOMAIN,oauthaccountmanager.googleapis.com
DOMAIN,oauth2.googleapis.com
DOMAIN,accounts.google.com

# ===== Firebase (App 核心推送与日志) =====
DOMAIN,firebaseinstallations.googleapis.com
DOMAIN,firebaselogging.googleapis.com
DOMAIN,firebaseappcheck.googleapis.com

# ===== AI Studio & Developer =====
DOMAIN-SUFFIX,aistudio.google.com
DOMAIN-SUFFIX,makersuite.google.com
DOMAIN,alkalimakersuite-pa.googleapis.com
DOMAIN,vertexai.googleapis.com
DOMAIN-SUFFIX,ai.google.dev
DOMAIN-SUFFIX,deepmind.google

# ===== Gemini Keyword =====
DOMAIN-KEYWORD,gemini
